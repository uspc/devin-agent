# Required: Your OpenAI API key (or compatible provider key)
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Base URL for OpenAI-compatible APIs (e.g., local LLM, Azure, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Model to use
# MODEL_NAME=gpt-3.5-turbo

# Optional: Max tokens for responses
# MAX_TOKENS=2048

# Optional: Temperature for response generation (0.0 - 2.0)
# TEMPERATURE=0.7
